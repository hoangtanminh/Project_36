<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Accordion?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.auctionhouse.client.controller.AccountController"
            style="-fx-background-color: linear-gradient(to bottom, #f7f2ea, #efe6da);">

    <top>
        <VBox spacing="16"
              style="-fx-background-color: linear-gradient(to right, #355c52, #4d776c);
                     -fx-padding: 22 28 22 28; -fx-border-color: #2c4e45; -fx-border-width: 0 0 1 0;">
            <HBox alignment="CENTER_LEFT" spacing="14">
                <Button text="Back" onAction="#goBack"
                        style="-fx-background-color: rgba(255,255,255,0.14); -fx-text-fill: #f8f5ef;
                               -fx-font-size: 12px; -fx-font-weight: bold;
                               -fx-border-color: rgba(255,255,255,0.24); -fx-border-width: 1;
                               -fx-border-radius: 999; -fx-background-radius: 999;
                               -fx-padding: 8 16; -fx-cursor: hand;"/>
                <Label text="Account Center"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #f8f5ef;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="Refresh" onAction="#refreshAccount"
                        style="-fx-background-color: #f3ede2; -fx-text-fill: #355c52;
                               -fx-font-size: 12px; -fx-font-weight: bold;
                               -fx-background-radius: 999; -fx-padding: 8 16; -fx-cursor: hand;"/>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="18">
                <StackPane minWidth="64" minHeight="64" maxWidth="64" maxHeight="64"
                           style="-fx-background-color: #f7efe2; -fx-background-radius: 999;">
                    <Label fx:id="avatarLabel" text="U"
                           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #355c52;"/>
                </StackPane>

                <VBox spacing="4">
                    <Label fx:id="accountNameLabel" text="User"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #f8f5ef;"/>
                    <Label fx:id="roleLabel" text="Bidder account"
                           style="-fx-font-size: 12px; -fx-text-fill: #dce9e3;"/>
                    <Label fx:id="accountSummaryLabel" text="Persistent account overview"
                           style="-fx-font-size: 12px; -fx-text-fill: #f6dcc0;"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <HBox spacing="12">
                    <VBox spacing="4"
                          style="-fx-background-color: rgba(248,245,239,0.14); -fx-background-radius: 18;
                                 -fx-border-color: rgba(255,255,255,0.16); -fx-border-radius: 18; -fx-padding: 12 18;">
                        <Label fx:id="balanceCaptionLabel" text="Persistent wallet balance"
                               style="-fx-font-size: 11px; -fx-text-fill: #dce9e3;"/>
                        <Label fx:id="walletBalanceLabel" text="\$0.00"
                               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #f8f5ef;"/>
                    </VBox>

                    <VBox alignment="CENTER" spacing="3"
                          style="-fx-background-color: #f3ede2; -fx-background-radius: 18; -fx-padding: 12 18;">
                        <Label text="Payments"
                               style="-fx-font-size: 11px; -fx-text-fill: #6b6a63;"/>
                        <Label fx:id="paymentCountLabel" text="0"
                               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #355c52;"/>
                    </VBox>

                    <VBox alignment="CENTER" spacing="3"
                          style="-fx-background-color: #f3ede2; -fx-background-radius: 18; -fx-padding: 12 18;">
                        <Label text="Joined"
                               style="-fx-font-size: 11px; -fx-text-fill: #6b6a63;"/>
                        <Label fx:id="joinedCountLabel" text="0"
                               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #355c52;"/>
                    </VBox>
                </HBox>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
            <content>
                <VBox spacing="16" maxWidth="980" style="-fx-padding: 22 28 28 28;">
                    <Label fx:id="accountStatusLabel" text=""
                           style="-fx-font-size: 12px; -fx-text-fill: #5a655f;"/>

                    <Accordion>
                        <panes>
                            <TitledPane text="Nap tien"
                                        expanded="true"
                                        style="-fx-font-size: 13px; -fx-font-weight: bold;">
                                <content>
                                    <VBox spacing="14"
                                          style="-fx-background-color: #fcf8f2; -fx-background-radius: 0 0 18 18;
                                                 -fx-border-color: #d9d1c7; -fx-border-width: 0 1 1 1; -fx-padding: 18;">
                                        <Label text="So du duoc luu tren server, tat app hoac tat server van con."
                                               style="-fx-font-size: 12px; -fx-text-fill: #6c746f;"/>
                                        <HBox spacing="12" alignment="CENTER_LEFT">
                                            <TextField fx:id="depositAmountField" promptText="Example: 150"
                                                       style="-fx-background-color: #f7f2ea; -fx-text-fill: #21332d;
                                                              -fx-prompt-text-fill: #8d8b84; -fx-border-color: #cfc7bc;
                                                              -fx-border-radius: 12; -fx-background-radius: 12;
                                                              -fx-padding: 11 14;"/>
                                            <Button text="Nap tien" onAction="#depositFunds"
                                                    style="-fx-background-color: #355c52; -fx-text-fill: #f8f5ef;
                                                           -fx-font-size: 12px; -fx-font-weight: bold;
                                                           -fx-background-radius: 999; -fx-padding: 10 20; -fx-cursor: hand;"/>
                                        </HBox>
                                    </VBox>
                                </content>
                            </TitledPane>

                            <TitledPane text="Thanh toan"
                                        style="-fx-font-size: 13px; -fx-font-weight: bold;">
                                <content>
                                    <HBox spacing="16"
                                          style="-fx-background-color: #fcf8f2; -fx-background-radius: 0 0 18 18;
                                                 -fx-border-color: #d9d1c7; -fx-border-width: 0 1 1 1; -fx-padding: 18;">
                                        <VBox spacing="10" HBox.hgrow="ALWAYS"
                                              style="-fx-background-color: #f4ede4; -fx-background-radius: 16; -fx-padding: 16;">
                                            <Label text="Finished auctions waiting for payment"
                                                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #21332d;"/>
                                            <Label fx:id="paymentSummaryLabel" text="No payment is pending for this account."
                                                   style="-fx-font-size: 12px; -fx-text-fill: #6c746f;"/>
                                            <ListView fx:id="payableAuctionListView" prefHeight="260"
                                                      style="-fx-background-color: transparent; -fx-control-inner-background: transparent;"/>
                                        </VBox>

                                        <VBox spacing="10" prefWidth="330"
                                              style="-fx-background-color: #fffdf9; -fx-background-radius: 18;
                                                     -fx-border-color: #d9d1c7; -fx-border-radius: 18; -fx-padding: 18;">
                                            <Label text="Payment detail"
                                                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #21332d;"/>
                                            <Separator/>
                                            <Label fx:id="paymentItemLabel" text="Select a finished auction from the payment list."
                                                   wrapText="true"
                                                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #21332d;"/>
                                            <Label fx:id="paymentAmountLabel" text="Amount due: --"
                                                   style="-fx-font-size: 12px; -fx-text-fill: #5e6963;"/>
                                            <Label fx:id="paymentStateLabel" text="Payment status: No auction selected"
                                                   wrapText="true"
                                                   style="-fx-font-size: 12px; -fx-text-fill: #5e6963;"/>
                                            <Label fx:id="paymentWinnerLabel" text="Winner: --"
                                                   style="-fx-font-size: 12px; -fx-text-fill: #5e6963;"/>
                                            <Region VBox.vgrow="ALWAYS"/>
                                            <Button fx:id="payNowButton" text="Thanh toan ngay" onAction="#paySelectedAuction"
                                                    style="-fx-background-color: #d7e6df; -fx-text-fill: #355c52;
                                                           -fx-font-size: 12px; -fx-font-weight: bold;
                                                           -fx-background-radius: 999; -fx-padding: 10 18; -fx-cursor: hand;"/>
                                        </VBox>
                                    </HBox>
                                </content>
                            </TitledPane>

                            <TitledPane text="Vat pham da tham gia dau gia"
                                        style="-fx-font-size: 13px; -fx-font-weight: bold;">
                                <content>
                                    <HBox spacing="16"
                                          style="-fx-background-color: #fcf8f2; -fx-background-radius: 0 0 18 18;
                                                 -fx-border-color: #d9d1c7; -fx-border-width: 0 1 1 1; -fx-padding: 18;">
                                        <VBox spacing="10" HBox.hgrow="ALWAYS"
                                              style="-fx-background-color: #f4ede4; -fx-background-radius: 16; -fx-padding: 16;">
                                            <Label text="Auctions you have joined"
                                                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #21332d;"/>
                                            <Label fx:id="joinedSummaryLabel" text="0 auctions joined"
                                                   style="-fx-font-size: 12px; -fx-text-fill: #6c746f;"/>
                                            <ListView fx:id="participatedAuctionListView" prefHeight="280"
                                                      style="-fx-background-color: transparent; -fx-control-inner-background: transparent;"/>
                                        </VBox>

                                        <VBox spacing="10" prefWidth="340"
                                              style="-fx-background-color: #fffdf9; -fx-background-radius: 18;
                                                     -fx-border-color: #d9d1c7; -fx-border-radius: 18; -fx-padding: 18;">
                                            <Label text="Auction detail"
                                                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #21332d;"/>
                                            <Separator/>
                                            <Label fx:id="joinedTitleLabel" text="Select one joined auction."
                                                   wrapText="true"
                                                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #21332d;"/>
                                            <Label fx:id="joinedStatusLabel" text="Status: --"
                                                   style="-fx-font-size: 12px; -fx-text-fill: #5e6963;"/>
                                            <Label fx:id="joinedPriceLabel" text="Current price: --"
                                                   style="-fx-font-size: 12px; -fx-text-fill: #5e6963;"/>
                                            <Label fx:id="joinedDetailLabel" text="Auction details and your participation summary will appear here."
                                                   wrapText="true"
                                                   style="-fx-font-size: 12px; -fx-text-fill: #5e6963;"/>
                                        </VBox>
                                    </HBox>
                                </content>
                            </TitledPane>

                            <TitledPane text="Log out"
                                        style="-fx-font-size: 13px; -fx-font-weight: bold;">
                                <content>
                                    <VBox spacing="12"
                                          style="-fx-background-color: #fcf8f2; -fx-background-radius: 0 0 18 18;
                                                 -fx-border-color: #d9d1c7; -fx-border-width: 0 1 1 1; -fx-padding: 18;">
                                        <Label text="End the current session and return to the login screen."
                                               style="-fx-font-size: 12px; -fx-text-fill: #6c746f;"/>
                                        <Button text="Log out" onAction="#handleLogout"
                                                style="-fx-background-color: transparent; -fx-text-fill: #a45e5e;
                                                       -fx-font-size: 12px; -fx-font-weight: bold;
                                                       -fx-border-color: #d8b6b6; -fx-border-width: 1;
                                                       -fx-border-radius: 999; -fx-background-radius: 999;
                                                       -fx-padding: 9 18; -fx-cursor: hand;"/>
                                    </VBox>
                                </content>
                            </TitledPane>
                        </panes>
                    </Accordion>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
