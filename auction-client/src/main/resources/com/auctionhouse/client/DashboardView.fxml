<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.auctionhouse.client.controller.DashboardController"
            style="-fx-background-color: #0f1118;">

    <top>
        <VBox spacing="14"
              style="-fx-padding: 18 24 18 24; -fx-background-color: #171a26;
                     -fx-border-color: #2b3047; -fx-border-width: 0 0 1 0;">

            <HBox alignment="CENTER_LEFT" spacing="16">
                <VBox spacing="4">
                    <Label text="AUCTION HOUSE"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #7c6af7;"/>
                    <Label text="Live marketplace dashboard"
                           style="-fx-font-size: 11px; -fx-text-fill: #7582a0;"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <HBox spacing="14" alignment="CENTER">
                    <VBox alignment="CENTER"
                          style="-fx-background-color: #111522; -fx-background-radius: 12;
                                 -fx-border-color: #2b3047; -fx-border-radius: 12; -fx-padding: 10 18;">
                        <Label text="LIVE" style="-fx-font-size: 10px; -fx-text-fill: #6a7693;"/>
                        <Label fx:id="liveMetricLabel" text="0"
                               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #5dcaa5;"/>
                    </VBox>
                    <VBox alignment="CENTER"
                          style="-fx-background-color: #111522; -fx-background-radius: 12;
                                 -fx-border-color: #2b3047; -fx-border-radius: 12; -fx-padding: 10 18;">
                        <Label text="MY AUCTIONS" style="-fx-font-size: 10px; -fx-text-fill: #6a7693;"/>
                        <Label fx:id="sellerMetricLabel" text="0"
                               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #f0c040;"/>
                    </VBox>
                    <VBox alignment="CENTER"
                          style="-fx-background-color: #111522; -fx-background-radius: 12;
                                 -fx-border-color: #2b3047; -fx-border-radius: 12; -fx-padding: 10 18;">
                        <Label text="TOTAL BIDS" style="-fx-font-size: 10px; -fx-text-fill: #6a7693;"/>
                        <Label fx:id="bidMetricLabel" text="0"
                               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #7c6af7;"/>
                    </VBox>
                </HBox>

                <Region HBox.hgrow="ALWAYS"/>

                <VBox alignment="CENTER_RIGHT" spacing="2">
                    <Label fx:id="currentUserLabel" text="User"
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label fx:id="roleBadgeLabel" text="BIDDER"
                           style="-fx-font-size: 10px; -fx-text-fill: #7c6af7;"/>
                </VBox>

                <Button fx:id="sellerBtn" text="Seller Panel" onAction="#goToSeller"
                        style="-fx-background-color: #5dcaa5; -fx-text-fill: #0f1b15;
                               -fx-font-weight: bold; -fx-background-radius: 10;
                               -fx-padding: 9 14; -fx-cursor: hand;"/>
                <Button text="Refresh" onAction="#refreshDashboard"
                        style="-fx-background-color: #232844; -fx-text-fill: #d6dcf0;
                               -fx-border-color: #343b5f; -fx-border-width: 1;
                               -fx-border-radius: 10; -fx-background-radius: 10;
                               -fx-padding: 9 14; -fx-cursor: hand;"/>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-background-color: #111522; -fx-background-radius: 14;
                         -fx-border-color: #2b3047; -fx-border-radius: 14; -fx-padding: 14;">
                <TextField fx:id="searchField" promptText="Search auctions..."
                           HBox.hgrow="ALWAYS"
                           style="-fx-background-color: #0d1019; -fx-text-fill: white;
                                  -fx-prompt-text-fill: #4c5673; -fx-border-color: #2b3047;
                                  -fx-border-width: 1; -fx-border-radius: 10; -fx-background-radius: 10;
                                  -fx-padding: 10 14; -fx-font-size: 12px;"/>
                <ChoiceBox fx:id="categoryChoice" prefWidth="220"
                           style="-fx-background-color: #0d1019; -fx-border-color: #2b3047;
                                  -fx-border-radius: 10; -fx-background-radius: 10;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="12" style="-fx-padding: 18 24 24 24; -fx-background-color: #0f1118;">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <VBox spacing="3">
                    <Label text="LIVE AUCTIONS"
                           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label text="Click any item to open the bidding detail view."
                           style="-fx-font-size: 11px; -fx-text-fill: #6a7693;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="actionStatusLabel" text=""
                       style="-fx-font-size: 12px; -fx-text-fill: #7c6af7;"/>
            </HBox>

            <VBox VBox.vgrow="ALWAYS"
                  style="-fx-background-color: #171a26; -fx-background-radius: 16;
                         -fx-border-color: #2b3047; -fx-border-radius: 16; -fx-padding: 10;">
                <ListView fx:id="auctionListView" VBox.vgrow="ALWAYS"
                          style="-fx-background-color: transparent;
                                 -fx-control-inner-background: transparent;
                                 -fx-background-insets: 0;
                                 -fx-border-color: transparent;"/>
            </VBox>
        </VBox>
    </center>
</BorderPane>
